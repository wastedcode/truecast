{
  "name": "@wastedcode/truecast",
  "version": "0.1.1",
  "description": "Install and run portable, versioned expert personas in Claude Code.",
  "license": "MIT",
  "author": "Inder Singh <inder@wastedcode.com>",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wastedcode/truecast.git"
  },
  "homepage": "https://github.com/wastedcode/truecast#readme",
  "bugs": {
    "url": "https://github.com/wastedcode/truecast/issues"
  },
  "keywords": ["claude", "claude-code", "subagent", "persona", "agent", "ai", "prompt", "cli"],
  "bin": {
    "truecast": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "execa": "^9.5.1",
    "is-path-inside": "^4.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.8.2",
    "simple-git": "^3.27.0",
    "smol-toml": "^1.3.1",
    "write-file-atomic": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.7.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.0"
  }
}
